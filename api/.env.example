# PostgreSQL (Neon or local) — required by Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# HTTP port (Nest listens on this inside the container/process)
PORT=3001

# CORS: comma-separated origins (no spaces), include local Next.js and production Vercel URL
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# JWT — use strong random strings in production
JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# Stripe — use test keys locally; never commit real secrets
STRIPE_SECRET_KEY="sk_test_..."

# Optional: used in some deployment setups (Prisma primarily needs DATABASE_URL)
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=
# DATABASE_PORT=
